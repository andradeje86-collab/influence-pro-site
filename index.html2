<script>
  // Scroll reveal
  const obs = new IntersectionObserver(es => {
    es.forEach(e => { if(e.isIntersecting) e.target.classList.add('on'); });
  }, {threshold: .08, rootMargin: '0px 0px -40px 0px'});
  document.querySelectorAll('.rv').forEach(el => obs.observe(el));

  // Animating phone value
  const vals = ['R$ 2.880','R$ 4.200','R$ 1.650','R$ 3.100','R$ 5.500'];
  let vi = 0;
  setInterval(() => {
    vi = (vi + 1) % vals.length;
    const el = document.getElementById('pv');
    if (!el) return;
    el.style.opacity = '0';
    setTimeout(() => { el.textContent = vals[vi]; el.style.opacity = '1'; }, 220);
  }, 2800);
</script>
